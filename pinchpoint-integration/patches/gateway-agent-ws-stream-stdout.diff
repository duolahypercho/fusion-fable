+function attachAccumulatedStream(result, streamChunks = []) {
+  const payload = result && typeof result === 'object' && !Array.isArray(result)
+    ? { ...result }
+    : { data: result };
+
+  if (!streamChunks.length) return payload;
+
+  const stdout = streamChunks
+    .filter(chunk => chunk?.channel === 'stdout')
+    .map(chunk => typeof chunk.data === 'string' ? chunk.data : '')
+    .join('');
+  const stderr = streamChunks
+    .filter(chunk => chunk?.channel === 'stderr')
+    .map(chunk => typeof chunk.data === 'string' ? chunk.data : '')
+    .join('');
+
+  payload.stream = streamChunks;
+  if (stdout && payload.stdout == null) payload.stdout = stdout;
+  if (stderr && payload.stderr == null) payload.stderr = stderr;
+  if (stdout && !payload.data) {
+    payload.data = stderr ? `${stdout}\n--- stderr ---\n${stderr}` : stdout;
+  }
+
+  return payload;
+}
