+function convertToolChoice(toolChoice) {
+  if (!toolChoice || toolChoice === 'auto') return undefined;
+  if (toolChoice === 'none') return { type: 'none' };
+  if (toolChoice === 'any') return { type: 'any' };
+  if (typeof toolChoice === 'string') return { type: 'tool', name: toolChoice };
+
+  const forcedName = toolChoice.function?.name || toolChoice.name;
+  if (forcedName) return { type: 'tool', name: forcedName };
+
+  if (['auto', 'none', 'any'].includes(toolChoice.type)) {
+    return toolChoice.type === 'auto' ? undefined : { type: toolChoice.type };
+  }
+
+  return undefined;
+}
