+function loadFusionFableSourcePrompt() {
+  if (!FUSION_FABLE_USE_SOURCE_PROMPT) return null;
+
+  try {
+    const stat = fs.statSync(FUSION_FABLE_SOURCE_PROMPT_PATH);
+    if (
+      cachedFusionFableSourcePrompt.path === FUSION_FABLE_SOURCE_PROMPT_PATH
+      && cachedFusionFableSourcePrompt.mtimeMs === stat.mtimeMs
+    ) {
+      return cachedFusionFableSourcePrompt.text;
+    }
+
+    const text = fs.readFileSync(FUSION_FABLE_SOURCE_PROMPT_PATH, 'utf8').trim();
+    cachedFusionFableSourcePrompt = {
+      path: FUSION_FABLE_SOURCE_PROMPT_PATH,
+      mtimeMs: stat.mtimeMs,
+      text,
+    };
+    console.log('[fusion-fable] source prompt loaded path=' + FUSION_FABLE_SOURCE_PROMPT_PATH + ' chars=' + text.length);
+    return text || null;
+  } catch (err) {
+    if (err?.code !== 'ENOENT') {
+      console.warn('[fusion-fable] source prompt unavailable: ' + err.message);
+    }
+    return null;
+  }
