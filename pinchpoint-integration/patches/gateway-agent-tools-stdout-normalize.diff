+function normalizeAgentResult(toolName, agentResult) {
+  if (toolName !== 'shell_exec' || !agentResult || typeof agentResult !== 'object') {
+    return agentResult;
+  }
+
+  const data = typeof agentResult.data === 'string' ? agentResult.data : '';
+  const stderrMarker = '\n--- stderr ---\n';
+  const markerIndex = data.indexOf(stderrMarker);
+  const stdout = typeof agentResult.stdout === 'string'
+    ? agentResult.stdout
+    : (markerIndex >= 0 ? data.slice(0, markerIndex) : data);
+  const stderr = typeof agentResult.stderr === 'string'
+    ? agentResult.stderr
+    : (markerIndex >= 0 ? data.slice(markerIndex + stderrMarker.length) : '');
+
+  return {
+    ...agentResult,
+    data: data || (stderr ? `${stdout}${stderrMarker}${stderr}` : stdout),
+    stdout,
+    stderr,
+    note: 'stdout/stderr normalized by gateway from the local agent data field',
+  };
+}
